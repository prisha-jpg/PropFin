generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model agreement_details {
  id                   String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  sales_order_id       String       @unique @db.Uuid
  agreement_number     String?      @db.VarChar(50)
  agreement_date       DateTime?    @db.Date
  registration_date    DateTime?    @db.Date
  stamp_duty_amount    Decimal?     @db.Decimal(15, 2)
  registration_fees    Decimal?     @db.Decimal(15, 2)
  notary_charges       Decimal?     @db.Decimal(15, 2)
  agreement_value      Decimal?     @db.Decimal(15, 2)
  sub_registrar_office String?      @db.VarChar(150)
  document_number      String?      @db.VarChar(50)
  agreement_file_path  String?
  remarks              String?
  created_at           DateTime     @default(now()) @db.Timestamptz(6)
  updated_at           DateTime     @default(now()) @db.Timestamptz(6)
  created_by           String?      @db.Uuid
  users                users?       @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales_orders         sales_orders @relation(fields: [sales_order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model audit_log {
  id                                String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  table_name                        String   @db.VarChar(80)
  record_id                         String   @db.Uuid
  action                            String   @db.VarChar(10)
  changed_by                        String?  @db.Uuid
  changed_at                        DateTime @default(now()) @db.Timestamptz(6)
  old_values                        Json?
  new_values                        Json?
  ip_address                        String?  @db.Inet
  session_id                        String?
  created_at                        DateTime @default(now()) @db.Timestamptz(6)
  updated_at                        DateTime @default(now()) @db.Timestamptz(6)
  created_by                        String?  @db.Uuid
  users_audit_log_changed_byTousers users?   @relation("audit_log_changed_byTousers", fields: [changed_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_audit_log_created_byTousers users?   @relation("audit_log_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([changed_at(sort: Desc)], map: "idx_audit_changed_at")
  @@index([table_name, record_id], map: "idx_audit_table_record")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model bank_documents {
  id                                       String                     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  document_number                          String                     @unique @db.VarChar(50)
  sales_order_id                           String                     @db.Uuid
  customer_id                              String                     @db.Uuid
  bank_id                                  String?                    @db.Uuid
  document_type                            String                     @db.VarChar(30)
  trigger_source                           String                     @default("manual") @db.VarChar(30)
  triggered_by_reference                   String?                    @db.VarChar(50)
  generation_date                          DateTime                   @db.Date
  valid_upto                               DateTime?                  @db.Date
  loan_account_number                      String?                    @db.VarChar(50)
  loan_amount                              Decimal?                   @db.Decimal(15, 2)
  bank_officer_name                        String?                    @db.VarChar(100)
  bank_officer_designation                 String?                    @db.VarChar(100)
  noc_purpose                              String?                    @db.VarChar(50)
  document_content                         Json?
  file_path                                String?
  status                                   String                     @default("draft") @db.VarChar(20)
  sent_to                                  String?                    @db.VarChar(150)
  sent_date                                DateTime?                  @db.Date
  acknowledged_date                        DateTime?                  @db.Date
  generated_by                             String?                    @db.Uuid
  created_at                               DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at                               DateTime                   @default(now()) @db.Timestamptz(6)
  created_by                               String?                    @db.Uuid
  bank_master                              bank_master?               @relation(fields: [bank_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_bank_documents_created_byTousers   users?                     @relation("bank_documents_created_byTousers", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customers                                customers                  @relation(fields: [customer_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_bank_documents_generated_byTousers users?                     @relation("bank_documents_generated_byTousers", fields: [generated_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales_orders                             sales_orders               @relation(fields: [sales_order_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payment_reminder_letters                 payment_reminder_letters[]

  @@index([customer_id], map: "idx_bank_docs_customer")
  @@index([sales_order_id], map: "idx_bank_docs_order")
  @@index([trigger_source], map: "idx_bank_docs_trigger")
}

model bank_master {
  id              String            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  bank_name       String            @db.VarChar(150)
  branch_name     String?           @db.VarChar(150)
  ifsc_code       String?           @db.VarChar(15)
  account_number  String?           @db.VarChar(30)
  micr_code       String?           @db.VarChar(10)
  address         String?
  city            String?           @db.VarChar(80)
  contact_person  String?           @db.VarChar(100)
  contact_phone   String?           @db.VarChar(15)
  is_active       Boolean           @default(true)
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @default(now()) @db.Timestamptz(6)
  created_by      String?           @db.Uuid
  bank_documents  bank_documents[]
  users           users?            @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customers       customers[]
  refund_requests refund_requests[]
}

model blocks {
  id                     String                    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  project_id             String                    @db.Uuid
  block_code             String                    @db.VarChar(20)
  block_name             String                    @db.VarChar(100)
  total_units            Int?
  is_active              Boolean                   @default(true)
  created_at             DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at             DateTime                  @default(now()) @db.Timestamptz(6)
  created_by             String?                   @db.Uuid
  users                  users?                    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects               projects                  @relation(fields: [project_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sales_orders           sales_orders[]
  units                  units[]
  paymentScheduleMasters payment_schedule_master[]

  @@unique([project_id, block_code])
}

