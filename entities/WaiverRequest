{
  "name": "WaiverRequest",
  "type": "object",
  "properties": {
    "request_number": {
      "type": "string",
      "description": "Unique waiver request number"
    },
    "customer_id": {
      "type": "string",
      "description": "Reference to customer"
    },
    "customer_name": {
      "type": "string",
      "description": "Customer name"
    },
    "sales_order_id": {
      "type": "string",
      "description": "Reference to sales order"
    },
    "project_name": {
      "type": "string",
      "description": "Project name"
    },
    "unit_number": {
      "type": "string",
      "description": "Unit number"
    },
    "waiver_type": {
      "type": "string",
      "description": "Type of waiver"
    },
    "interest_amount": {
      "type": "number",
      "description": "Total interest amount"
    },
    "waiver_amount": {
      "type": "number",
      "description": "Waiver amount requested"
    },
    "reason": {
      "type": "string",
      "description": "Reason for waiver"
    },
    "request_date": {
      "type": "string",
      "format": "date",
      "description": "Request date"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "under_review",
        "approved",
        "rejected"
      ],
      "default": "pending",
      "description": "Request status"
    },
    "approved_by": {
      "type": "string",
      "description": "Approved by"
    },
    "approval_date": {
      "type": "string",
      "format": "date",
      "description": "Approval date"
    },
    "remarks": {
      "type": "string",
      "description": "Remarks"
    }
  },
  "required": [
    "customer_id",
    "waiver_amount",
    "reason"
  ]
}