{
  "name": "DemandLetter",
  "type": "object",
  "properties": {
    "demand_number": {
      "type": "string",
      "description": "Unique demand letter number"
    },
    "customer_id": {
      "type": "string",
      "description": "Reference to customer"
    },
    "customer_name": {
      "type": "string",
      "description": "Customer name"
    },
    "sales_order_id": {
      "type": "string",
      "description": "Reference to sales order"
    },
    "project_name": {
      "type": "string",
      "description": "Project name"
    },
    "unit_number": {
      "type": "string",
      "description": "Unit number"
    },
    "demand_type": {
      "type": "string",
      "enum": [
        "first",
        "subsequent"
      ],
      "description": "First or subsequent demand"
    },
    "demand_date": {
      "type": "string",
      "format": "date",
      "description": "Demand letter date"
    },
    "due_date": {
      "type": "string",
      "format": "date",
      "description": "Payment due date"
    },
    "installment_number": {
      "type": "number",
      "description": "Installment sequence number"
    },
    "milestone_description": {
      "type": "string",
      "description": "Construction milestone description"
    },
    "demand_amount": {
      "type": "number",
      "description": "Amount demanded"
    },
    "gst_amount": {
      "type": "number",
      "description": "GST on demand"
    },
    "total_demand": {
      "type": "number",
      "description": "Total demand including taxes"
    },
    "amount_paid": {
      "type": "number",
      "description": "Amount paid against this demand"
    },
    "balance": {
      "type": "number",
      "description": "Balance remaining"
    },
    "status": {
      "type": "string",
      "enum": [
        "generated",
        "sent",
        "partially_paid",
        "paid",
        "overdue"
      ],
      "default": "generated",
      "description": "Demand letter status"
    }
  },
  "required": [
    "customer_id",
    "sales_order_id",
    "demand_amount"
  ]
}