{
  "name": "Customer",
  "type": "object",
  "properties": {
    "customer_code": {
      "type": "string",
      "description": "System-generated unique Customer Identification Number (CIF)"
    },
    "full_name": {
      "type": "string",
      "description": "Full name of the customer"
    },
    "email": {
      "type": "string",
      "description": "Email address"
    },
    "phone": {
      "type": "string",
      "description": "Phone number"
    },
    "pan_number": {
      "type": "string",
      "description": "PAN card number"
    },
    "aadhaar_number": {
      "type": "string",
      "description": "Aadhaar card number"
    },
    "address": {
      "type": "string",
      "description": "Residential address"
    },
    "city": {
      "type": "string",
      "description": "City"
    },
    "state": {
      "type": "string",
      "description": "State"
    },
    "pincode": {
      "type": "string",
      "description": "PIN code"
    },
    "date_of_birth": {
      "type": "string",
      "format": "date",
      "description": "Date of birth"
    },
    "occupation": {
      "type": "string",
      "description": "Occupation"
    },
    "company_name": {
      "type": "string",
      "description": "Company/employer name"
    },
    "has_active_loan": {
      "type": "boolean",
      "description": "Whether customer has an active home loan"
    },
    "loan_bank_name": {
      "type": "string",
      "description": "Loan bank name"
    },
    "loan_account_number": {
      "type": "string",
      "description": "Loan account number"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "blocked"
      ],
      "default": "active",
      "description": "Customer status"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes"
    }
  },
  "required": [
    "full_name",
    "phone"
  ]
}