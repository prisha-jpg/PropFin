{
  "name": "RefundRequest",
  "type": "object",
  "properties": {
    "request_number": {
      "type": "string",
      "description": "Unique refund request number"
    },
    "customer_id": {
      "type": "string",
      "description": "Reference to customer"
    },
    "customer_name": {
      "type": "string",
      "description": "Customer name"
    },
    "sales_order_id": {
      "type": "string",
      "description": "Reference to sales order"
    },
    "project_name": {
      "type": "string",
      "description": "Project name"
    },
    "unit_number": {
      "type": "string",
      "description": "Unit number"
    },
    "request_date": {
      "type": "string",
      "format": "date",
      "description": "Request date"
    },
    "refund_amount": {
      "type": "number",
      "description": "Refund amount"
    },
    "reason": {
      "type": "string",
      "enum": [
        "cancellation",
        "overpayment",
        "scheme_change",
        "other"
      ],
      "description": "Reason for refund"
    },
    "reason_details": {
      "type": "string",
      "description": "Detailed reason"
    },
    "bank_name": {
      "type": "string",
      "description": "Beneficiary bank name"
    },
    "account_number": {
      "type": "string",
      "description": "Bank account number"
    },
    "ifsc_code": {
      "type": "string",
      "description": "IFSC code"
    },
    "account_holder_name": {
      "type": "string",
      "description": "Account holder name"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "under_review",
        "approved",
        "rejected",
        "processed"
      ],
      "default": "pending",
      "description": "Request status"
    },
    "approved_by": {
      "type": "string",
      "description": "Approved by"
    },
    "approval_date": {
      "type": "string",
      "format": "date",
      "description": "Approval date"
    },
    "remarks": {
      "type": "string",
      "description": "Remarks"
    }
  },
  "required": [
    "customer_id",
    "refund_amount",
    "reason"
  ]
}